# ═══════════════════════════════════════════════════════════════
# AIGoLab 환경변수 예시
# 실제 값은 `.env.local` 에 넣으세요 (gitignore 됨)
# Vercel 배포 시에는 Dashboard → Settings → Environment Variables 에 등록
#
# ⚠️ 보안 주의 — 프리픽스 정책:
#   - `VITE_*`  → 클라이언트 번들에 그대로 포함됨 (누구나 DevTools 로 추출 가능)
#                 → 공개돼도 안전한 값만 사용 (Supabase URL/anon key 등)
#   - 프리픽스 없음 → 서버 전용 (Vercel Function, import.meta.env 에서 접근 불가)
#                 → 실제 비밀값(봇 토큰, 서비스 롤 키 등)은 반드시 이쪽
# ═══════════════════════════════════════════════════════════════

# ─── Supabase (필수) ────────────────────────────────────────────
# 둘 다 VITE_ 공개용 — anon key 는 RLS 로 보호됨
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── 슈퍼 관리자 이메일 (선택) ──────────────────────────────────
# 쉼표로 구분. 이 이메일들은 클라이언트에서 자동으로 admin 으로 인식됨.
# (실제 DB 권한은 별도 — Supabase 에 bootstrap SQL 실행 필요)
#
# 하이브리드 전략:
#   - VITE_ADMIN_EMAILS: 절대 권한 (env 로만 관리, 코드 공개 안 됨)
#   - user_entitlements 테이블: 추가 관리자·세부 혜택 (DB 에서 관리)
VITE_ADMIN_EMAILS=your@email.com

# ─── 앱 URL (선택) ──────────────────────────────────────────────
# 관리자 알림 링크 등에 사용. 미설정 시 https://aigolab.co.kr 기본값.
VITE_APP_URL=https://aigolab.co.kr

# ─── 텔레그램 봇 알림 (선택) — ⚠️ 반드시 서버 전용으로 ───────────
# 이 두 값은 절대 VITE_ 접두사를 붙이지 말 것. Vercel Function
# (`/api/notify-admin`) 에서만 사용됨.
#
# 로컬 개발 시: `.env.local` 에 이 이름 그대로 추가 + `vercel dev` 로 실행
# 프로덕션:     Vercel Dashboard → Environment Variables 에 등록
#
# 설정 방법:
#   1. 텔레그램에서 @BotFather → /newbot → 봇 생성 → 토큰 복사
#   2. 생성한 봇에게 아무 메시지 전송
#   3. https://api.telegram.org/bot{토큰}/getUpdates 접속 → chat.id 확인
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=987654321

# ─── (옵션) OpenAI / 기타 ────────────────────────────────────────
# VITE_OPENAI_API_KEY=sk-...
